# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://appuser:YOUR_PASSWORD@app-postgres:5432/appdb?schema=public"

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Public URL of the app (used by NextAuth for callbacks)
AUTH_URL="https://yourdomain.com"

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ── Admin / Access control ─────────────────────────────────────────────────────
# Email address of the first admin user (auto-approved on first sign-in)
ALLOWED_EMAIL="admin@example.com"

# ── Cron job authentication ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used as Bearer token for /api/cron/* endpoints
CRON_SECRET="your-cron-secret-here"

# ── Optional overrides ─────────────────────────────────────────────────────────
# Default CAD/USD exchange rate (fallback if /api/fx fails)
# DEFAULT_FX_RATE=1.36
