# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://appuser:***@app-postgres:5432/appdb?schema=public"

# ── Single-user mode ──────────────────────────────────────────────────────────
# Fixed User.id used for all browser sessions. Keep the existing User table row.
DIVIDENDTRACKER_SINGLE_USER_ID="sangbong"

# ── Cron job authentication ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used as Bearer token for /api/cron/* endpoints
CRON_SECRET="your-c...here"

# ── Optional overrides ─────────────────────────────────────────────────────────
# Default CAD/USD exchange rate (fallback if /api/fx fails)
# DEFAULT_FX_RATE=1.36
