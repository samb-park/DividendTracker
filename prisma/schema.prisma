generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id           // Google OAuth sub
  email      String      @unique
  name       String?
  image      String?
  approved   Boolean     @default(false)
  role       UserRole    @default(USER)
  createdAt  DateTime    @default(now())
  portfolios Portfolio[]
}

enum UserRole {
  ADMIN
  USER
}

model Portfolio {
  id               String            @id @default(cuid())
  userId           String?
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  name             String
  accountType      AccountType       @default(NON_REG)
  cashCAD          Decimal?          @db.Decimal(18, 2)
  cashUSD          Decimal?          @db.Decimal(18, 2)
  createdAt        DateTime          @default(now())
  holdings         Holding[]
  cashTransactions CashTransaction[]
}

model Holding {
  id           String        @id @default(cuid())
  portfolioId  String
  ticker       String
  name         String?
  currency     Currency      @default(USD)
  quantity     Decimal?      @db.Decimal(18, 6)
  avgCost      Decimal?      @db.Decimal(18, 4)
  portfolio    Portfolio     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  createdAt    DateTime      @default(now())

  @@unique([portfolioId, ticker])
}

model Transaction {
  id         String            @id @default(cuid())
  holdingId  String
  action     TransactionAction
  date       DateTime
  quantity   Decimal           @db.Decimal(18, 6)
  price      Decimal           @db.Decimal(18, 4)
  commission Decimal           @default(0) @db.Decimal(18, 4)
  fxRateCAD  Decimal?          @db.Decimal(10, 6)  // CAD/USD rate on transaction date (for CRA reporting)
  notes      String?
  holding    Holding           @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())

  @@index([holdingId, action, date])
}

model CashTransaction {
  id          String     @id @default(cuid())
  portfolioId String
  action      CashAction
  date        DateTime
  amount      Decimal    @db.Decimal(18, 2)
  currency    Currency   @default(CAD)
  notes       String?
  portfolio   Portfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())

  @@index([portfolioId, date])
  @@index([portfolioId, action, date, amount, currency])
}

enum TransactionAction {
  BUY
  SELL
  DIVIDEND
}

enum CashAction {
  DEPOSIT
  WITHDRAWAL
}

enum Currency {
  CAD
  USD
}

enum AccountType {
  TFSA
  RRSP
  FHSA
  NON_REG
  CASH
}

// Key-value store for app settings (e.g. Questrade token)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Daily portfolio value snapshots for CAGR / MDD charting
model PortfolioSnapshot {
  id           String   @id @default(cuid())
  userId       String?
  date         DateTime @db.Date
  totalCAD     Decimal  @db.Decimal(18, 2)
  costBasisCAD Decimal  @db.Decimal(18, 2)
  cashCAD      Decimal  @db.Decimal(18, 2)
  createdAt    DateTime @default(now())

  @@unique([userId, date])
}
